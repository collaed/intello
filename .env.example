# L'Intello — Environment Configuration
# Copy to .env and fill in your values

# === Authentication ===
INTELLO_TOKEN=changeme                    # Bearer token + cookie + login password
INTELLO_USERS={"admin": "changeme"}       # JSON: {"username": "password", ...}
INTELLO_PREMIUM_USERS=admin               # Comma-separated usernames who can use paid models

# === LLM API Keys (add whichever you have) ===
# Free tiers:
GOOGLE_API_KEY=                           # Gemini (free, 1500 req/day) — https://aistudio.google.com/apikey
GOOGLE_API_KEY_2=                         # Second Gemini key (doubles quota)
GROQ_API_KEY=                             # Groq (free, fast) — https://console.groq.com/keys
MISTRAL_API_KEY=                          # Mistral (free tier) — https://console.mistral.ai/api-keys
DEEPSEEK_API_KEY=                         # DeepSeek (near-free) — https://platform.deepseek.com/api_keys
COHERE_API_KEY=                           # Cohere (free tier) — https://dashboard.cohere.com/api-keys
OPENROUTER_API_KEY=                       # OpenRouter (free models) — https://openrouter.ai/keys
CLOUDFLARE_API_KEY=                       # Cloudflare Workers AI (10K free/day)
CLOUDFLARE_ACCOUNT_ID=                    # Required for Cloudflare

# Paid:
OPENAI_API_KEY=                           # OpenAI — https://platform.openai.com/api-keys
ANTHROPIC_API_KEY=                        # Anthropic Claude — https://console.anthropic.com/settings/keys
XAI_API_KEY=                              # x.ai Grok
NANOGPT_API_KEY=                          # NanoGPT meta-provider

# Local:
OLLAMA_URL=                               # Ollama (e.g. http://ollama:11434/v1)

# === Google Drive OAuth (optional) ===
GDRIVE_CREDENTIALS=/data/gdrive_credentials.json
GDRIVE_TOKEN=/data/gdrive_token.json

# === Optional ===
INTELLO_URL=https://your-domain.com       # Used as OpenRouter referer
